{
  "tools": [
    {
      "type": "function",
      "function": {
        "name": "search_orders",
        "description": "Search active or fulfilled orders for one customer.",
        "parameters": {
          "type": "object",
          "properties": {
            "status": {
              "type": "string",
              "enum": ["open", "fulfilled"]
            },
            "customer_id": {
              "type": "string"
            },
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 50
            }
          },
          "required": ["status", "customer_id"],
          "additionalProperties": false
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "get_customer",
        "description": "Fetch one customer.",
        "parameters": {
          "type": "object",
          "properties": {
            "customer_id": {
              "type": "string"
            }
          },
          "required": ["customer_id"],
          "additionalProperties": false
        }
      }
    }
  ]
}
